      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(query_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "{{stage}} P95",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
