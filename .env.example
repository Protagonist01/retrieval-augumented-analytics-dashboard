# ─────────────────────────────────────────────
#  RAA Dashboard — Environment Configuration
#  Copy to .env and fill in your values.
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# "openai"  → use OpenAI API (requires OPENAI_API_KEY)
# "ollama"  → use local Ollama (requires OLLAMA_BASE_URL)
LLM_PROVIDER=openai

# OpenRouter free settings (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY is intentionally blank; use OPENROUTER_API_KEY below.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openrouter/free
OPENAI_MAX_TOKENS=1024

# OpenRouter settings.
# openrouter/free is a router that chooses an available free model for each request.
OPENROUTER_API_KEY=your-openrouter-free-api-key
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=RAA Dashboard

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=sqlcoder:7b

# ── Database ──────────────────────────────────
# Path to the directory containing CSV/Parquet data files.
# DuckDB reads these directly — no import step required.
DUCKDB_DATA_DIR=./data/sample

# ── Execution Limits ──────────────────────────
MAX_RESULT_ROWS=10000
QUERY_TIMEOUT_SECONDS=5

# ── Redis Cache ───────────────────────────────
# Schema and query result caching. App degrades gracefully if unavailable.
REDIS_URL=redis://localhost:6379
SCHEMA_CACHE_TTL_SECONDS=300
QUERY_CACHE_TTL_SECONDS=60

# ── API ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ── Observability ─────────────────────────────
LOG_LEVEL=INFO
# "json" for production (Loki-compatible), "pretty" for local dev
LOG_FORMAT=pretty

# ── Eval ──────────────────────────────────────
# Model used when running: make eval
# Override with: EVAL_MODEL=gpt-4o make eval
EVAL_MODEL=gpt-4o
EVAL_GOLDEN_SET=evals/golden_set.jsonl
EVAL_RESULTS_DIR=evals/results
